import { useState } from 'react'

function disableButton() {
  const [disabled, setDisabled] = useState(false);
  return (
    <div>
      <button 
      disabled = {disabled}
      onClick={()=>setDisabled(true)}>Click me</button>
    </div>
  )
}
export default disableButton
