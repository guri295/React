import React, { useState } from "react";
function PasswordValidator() {
  const [password, setPassword] = useState("");
  const firstCapital =
    password.length > 0 && password[0] === password[0].toUpperCase();
  const hasSmallLetter = /[a-z]/.test(password);
  const hasSpecialChar = /[^A-Za-z0-9]/.test(password);
  const hasNumber = /[0-9]/.test(password);
  return (
    <div>
      <h2>Password Validator</h2>
      <input
        type="text"
        placeholder="Enter Password"
        value={password}
        onChange={(e) => setPassword(e.target.value)}
      />
      <p style={{ color: firstCapital ? "green" : "red" }}>
        First character should be Capital
      </p>
      <p style={{ color: hasSmallLetter ? "green" : "red" }}>
        Must contain one small letter
      </p>
      <p style={{ color: hasSpecialChar ? "green" : "red" }}>
        Must contain one special character
      </p>
      <p style={{ color: hasNumber ? "green" : "red" }}>
        Must contain one number (0-9)
      </p>
    </div>
  );
}
export default PasswordValidator;
