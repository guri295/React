enum SeatType{
  Regular,
  Premium,
  VIP
}
type Ticket = [string, number, SeatType, number];
function calculateDiscount(ticket: Ticket): number{
  let price = ticket[3];
  let seatType = ticket[2];
  if(seatType == SeatType.Premium){
    price = price - (price * 10/100);
  }
  else if(seatType == SeatType.VIP){
    price = price - (price * 20/100);
  }
  return price;
}
let ticket1: Ticket = ["Avengers", 12, SeatType.Premium, 500];
let finalPrice = calculateDiscount(ticket1);
console.log("Final Ticket Price:", finalPrice);
